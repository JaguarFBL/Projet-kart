<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard Karting</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js">
  // Sparkline
  const canvas = document.getElementById('sparkline');
  const ctx = canvas.getContext('2d');
  function drawSparkline() {
    const W = canvas.parentElement.clientWidth - 44;
    canvas.width = W;
    const chargeData = [82,81,81,80,80,79,79,78,78,78];
    const tempData   = [24,25,25,26,27,27,28,28,28,28];
    const H=70, pad=4, pts=chargeData.length;
    const xStep=(W-pad*2)/(pts-1);
    function toX(i){return pad+i*xStep;}
    function toYcharge(v){return H-pad-((v-70)/20)*(H-pad*2);}
    function toYtemp(v){return H-pad-((v-20)/15)*(H-pad*2);}
    ctx.clearRect(0,0,W,H);
    ctx.strokeStyle='#e8e6e0';ctx.lineWidth=1;
    [0.25,0.5,0.75].forEach(r=>{const y=pad+r*(H-pad*2);ctx.beginPath();ctx.moveTo(pad,y);ctx.lineTo(W-pad,y);ctx.stroke();});
    ctx.beginPath();ctx.moveTo(toX(0),toYcharge(chargeData[0]));
    chargeData.forEach((v,i)=>ctx.lineTo(toX(i),toYcharge(v)));
    ctx.lineTo(toX(pts-1),H);ctx.lineTo(toX(0),H);ctx.closePath();
    ctx.fillStyle='rgba(45,158,107,0.08)';ctx.fill();
    ctx.beginPath();chargeData.forEach((v,i)=>i===0?ctx.moveTo(toX(i),toYcharge(v)):ctx.lineTo(toX(i),toYcharge(v)));
    ctx.strokeStyle='#2d9e6b';ctx.lineWidth=2;ctx.lineJoin='round';ctx.stroke();
    ctx.beginPath();tempData.forEach((v,i)=>i===0?ctx.moveTo(toX(i),toYtemp(v)):ctx.lineTo(toX(i),toYtemp(v)));
    ctx.strokeStyle='#c98a1a';ctx.lineWidth=2;ctx.setLineDash([4,3]);ctx.stroke();ctx.setLineDash([]);
    [[toX(pts-1),toYcharge(chargeData[pts-1]),'#2d9e6b'],[toX(pts-1),toYtemp(tempData[pts-1]),'#c98a1a']].forEach(([x,y,c])=>{
      ctx.beginPath();ctx.arc(x,y,4,0,Math.PI*2);ctx.fillStyle=c;ctx.fill();ctx.strokeStyle='#fff';ctx.lineWidth=1.5;ctx.stroke();
    });
  }
  drawSparkline();
  window.addEventListener('resize', drawSparkline);

  // Forecast
  const forecastNow = new Date();
  const forecastSlots = [
    {offset:0,icon:'☀️',temp:'7.4°',rain:'0%'},
    {offset:30,icon:'☀️',temp:'8.1°',rain:'0%'},
    {offset:60,icon:'🌤️',temp:'9.0°',rain:'5%'},
    {offset:90,icon:'🌤️',temp:'9.8°',rain:'5%'},
    {offset:120,icon:'⛅',temp:'10.5°',rain:'10%'},
  ];
  forecastSlots.forEach(f=>{
    const t=new Date(forecastNow.getTime()+f.offset*60000);
    const hh=String(t.getHours()).padStart(2,'0');
    const mm=String(t.getMinutes()).padStart(2,'0');
    const label=f.offset===0?'Maintenant':hh+':'+mm;
    document.getElementById('forecastRow').innerHTML+=`<div style="flex:1;background:var(--bg);border-radius:10px;padding:10px 6px;text-align:center;display:flex;flex-direction:column;gap:4px"><div style="font-size:10px;font-weight:500;letter-spacing:.06em;color:var(--muted)">${label}</div><div style="font-size:20px">${f.icon}</div><div style="font-family:'DM Mono',monospace;font-size:13px">${f.temp}</div><div style="font-size:10px;color:var(--muted)">${f.rain}</div></div>`;
  });

  // ── SPARKLINE CONDITIONS ──
  const sparkCanvas = document.getElementById('sparkline');
  if (sparkCanvas) {
    const sCtx = sparkCanvas.getContext('2d');
    function drawSparkline() {
      const W = sparkCanvas.parentElement.clientWidth - 44;
      sparkCanvas.width = W;
      const cd=[82,81,81,80,80,79,79,78,78,78], td=[24,25,25,26,27,27,28,28,28,28];
      const H=70, pad=4, pts=cd.length, xStep=(W-pad*2)/(pts-1);
      const toX=i=>pad+i*xStep;
      const toYc=v=>H-pad-((v-70)/20)*(H-pad*2);
      const toYt=v=>H-pad-((v-20)/15)*(H-pad*2);
      sCtx.clearRect(0,0,W,H);
      sCtx.strokeStyle='#e8e6e0'; sCtx.lineWidth=1;
      [.25,.5,.75].forEach(r=>{const y=pad+r*(H-pad*2);sCtx.beginPath();sCtx.moveTo(pad,y);sCtx.lineTo(W-pad,y);sCtx.stroke();});
      sCtx.beginPath(); sCtx.moveTo(toX(0),toYc(cd[0]));
      cd.forEach((v,i)=>sCtx.lineTo(toX(i),toYc(v)));
      sCtx.lineTo(toX(pts-1),H); sCtx.lineTo(toX(0),H); sCtx.closePath();
      sCtx.fillStyle='rgba(45,158,107,.08)'; sCtx.fill();
      sCtx.beginPath(); cd.forEach((v,i)=>i===0?sCtx.moveTo(toX(i),toYc(v)):sCtx.lineTo(toX(i),toYc(v)));
      sCtx.strokeStyle='#2d9e6b'; sCtx.lineWidth=2; sCtx.lineJoin='round'; sCtx.stroke();
      sCtx.beginPath(); td.forEach((v,i)=>i===0?sCtx.moveTo(toX(i),toYt(v)):sCtx.lineTo(toX(i),toYt(v)));
      sCtx.strokeStyle='#c98a1a'; sCtx.lineWidth=2; sCtx.setLineDash([4,3]); sCtx.stroke(); sCtx.setLineDash([]);
      [[toX(pts-1),toYc(cd[pts-1]),'#2d9e6b'],[toX(pts-1),toYt(td[pts-1]),'#c98a1a']].forEach(([x,y,c])=>{
        sCtx.beginPath(); sCtx.arc(x,y,4,0,Math.PI*2); sCtx.fillStyle=c; sCtx.fill();
        sCtx.strokeStyle='#fff'; sCtx.lineWidth=1.5; sCtx.stroke();
      });
    }
    drawSparkline();
    window.addEventListener('resize', drawSparkline);
  }

  // ── FORECAST CONDITIONS ──
  const forecastEl = document.getElementById('forecastRow');
  if (forecastEl) {
    const fNow = new Date();
    [{offset:0,icon:'☀️',temp:'7.4°',rain:'0%'},{offset:30,icon:'☀️',temp:'8.1°',rain:'0%'},
     {offset:60,icon:'🌤️',temp:'9.0°',rain:'5%'},{offset:90,icon:'🌤️',temp:'9.8°',rain:'5%'},
     {offset:120,icon:'⛅',temp:'10.5°',rain:'10%'}].forEach(f=>{
      const t=new Date(fNow.getTime()+f.offset*60000);
      const label=f.offset===0?'Maintenant':String(t.getHours()).padStart(2,'0')+':'+String(t.getMinutes()).padStart(2,'0');
      forecastEl.innerHTML+='<div style="flex:1;background:var(--bg);border-radius:10px;padding:10px 6px;text-align:center;display:flex;flex-direction:column;gap:4px">'
        +'<div style="font-size:10px;font-weight:500;letter-spacing:.06em;color:var(--muted)">'+label+'</div>'
        +'<div style="font-size:20px">'+f.icon+'</div>'
        +'<div style="font-family:DM Mono,monospace;font-size:13px">'+f.temp+'</div>'
        +'<div style="font-size:10px;color:var(--muted)">'+f.rain+'</div></div>';
    });
  }

  // ── SPARKLINE
  const canvas = document.getElementById('sparkline');
  const ctx = canvas.getContext('2d');
  function drawSparkline() {
    const W = canvas.parentElement.clientWidth - 44;
    canvas.width = W;
    const chargeData = [82,81,81,80,80,79,79,78,78,78];
    const tempData   = [24,25,25,26,27,27,28,28,28,28];
    const H=70, pad=4, pts=chargeData.length, xStep=(W-pad*2)/(pts-1);
    function toX(i){return pad+i*xStep;}
    function toYcharge(v){return H-pad-((v-70)/20)*(H-pad*2);}
    function toYtemp(v){return H-pad-((v-20)/15)*(H-pad*2);}
    ctx.clearRect(0,0,W,H);
    ctx.strokeStyle='#e8e6e0'; ctx.lineWidth=1;
    [0.25,0.5,0.75].forEach(r=>{const y=pad+r*(H-pad*2);ctx.beginPath();ctx.moveTo(pad,y);ctx.lineTo(W-pad,y);ctx.stroke();});
    ctx.beginPath(); ctx.moveTo(toX(0),toYcharge(chargeData[0]));
    chargeData.forEach((v,i)=>ctx.lineTo(toX(i),toYcharge(v)));
    ctx.lineTo(toX(pts-1),H); ctx.lineTo(toX(0),H); ctx.closePath();
    ctx.fillStyle='rgba(45,158,107,0.08)'; ctx.fill();
    ctx.beginPath(); chargeData.forEach((v,i)=>i===0?ctx.moveTo(toX(i),toYcharge(v)):ctx.lineTo(toX(i),toYcharge(v)));
    ctx.strokeStyle='#2d9e6b'; ctx.lineWidth=2; ctx.lineJoin='round'; ctx.stroke();
    ctx.beginPath(); tempData.forEach((v,i)=>i===0?ctx.moveTo(toX(i),toYtemp(v)):ctx.lineTo(toX(i),toYtemp(v)));
    ctx.strokeStyle='#c98a1a'; ctx.lineWidth=2; ctx.setLineDash([4,3]); ctx.stroke(); ctx.setLineDash([]);
    [[toX(pts-1),toYcharge(chargeData[pts-1]),'#2d9e6b'],[toX(pts-1),toYtemp(tempData[pts-1]),'#c98a1a']].forEach(([x,y,c])=>{
      ctx.beginPath(); ctx.arc(x,y,4,0,Math.PI*2); ctx.fillStyle=c; ctx.fill();
      ctx.strokeStyle='#fff'; ctx.lineWidth=1.5; ctx.stroke();
    });
  }
  drawSparkline();
  window.addEventListener('resize', drawSparkline);

  // ── FORECAST
  const forecastNow = new Date();
  [{offset:0,icon:'☀️',temp:'7.4°',rain:'0%'},{offset:30,icon:'☀️',temp:'8.1°',rain:'0%'},
   {offset:60,icon:'🌤️',temp:'9.0°',rain:'5%'},{offset:90,icon:'🌤️',temp:'9.8°',rain:'5%'},
   {offset:120,icon:'⛅',temp:'10.5°',rain:'10%'}].forEach(f=>{
    const t=new Date(forecastNow.getTime()+f.offset*60000);
    const hh=String(t.getHours()).padStart(2,'0'), mm=String(t.getMinutes()).padStart(2,'0');
    const label=f.offset===0?'Maintenant':`${hh}:${mm}`;
    document.getElementById('forecastRow').innerHTML+=`
      <div style="flex:1;background:var(--bg);border-radius:10px;padding:10px 6px;text-align:center;display:flex;flex-direction:column;gap:4px;">
        <div style="font-size:10px;font-weight:500;letter-spacing:.06em;color:var(--muted);">${label}</div>
        <div style="font-size:20px;">${f.icon}</div>
        <div style="font-family:'DM Mono',monospace;font-size:13px;">${f.temp}</div>
        <div style="font-size:10px;color:var(--muted);">${f.rain}</div>
      </div>`;
  });
</script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background: #fff;
      color: #111;
      font-size: 13px;
      font-weight: 400;
    }

    /* ── HEADER ── */
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 24px;
      border-bottom: 1px solid #e8e8e8;
    }

    .header-title { font-size: 14px; font-weight: 500; }

    .avatar {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: #ccc;
      cursor: pointer;
    }

    /* ── TOOLBAR ── */
    .toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 24px;
      border-bottom: 1px solid #e8e8e8;
      height: 40px;
    }

    .tabs { display: flex; gap: 0; }

    .tabs button {
      background: none;
      border: none;
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 400;
      color: #888;
      padding: 0 14px;
      height: 40px;
      cursor: pointer;
      border-bottom: 1.5px solid transparent;
      transition: color .15s, border-color .15s;
    }

    .tabs button.active { color: #111; border-bottom-color: #111; }
    .tabs button:hover:not(.active) { color: #444; }

    .search-box {
      display: flex; align-items: center; gap: 6px;
      border: 1px solid #e8e8e8;
      border-radius: 6px;
      padding: 5px 10px;
      width: 180px;
    }

    .search-box input {
      border: none; background: transparent;
      font-family: 'Inter', sans-serif;
      font-size: 12px; outline: none; width: 100%; color: #888;
    }

    /* ── PAGES ── */
    .page { display: none; }
    .page.active { display: block; animation: fadeIn .2s ease; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(4px); } to { opacity:1; transform:translateY(0); } }

    /* ── LAYOUT ── */
    .content { padding: 24px; }

    .row {
      display: grid;
      gap: 16px;
      margin-bottom: 16px;
    }

    .row-2 { grid-template-columns: 1fr 1fr; }
    .row-3 { grid-template-columns: 1fr 1fr 1fr; }
    .row-4 { grid-template-columns: repeat(4,1fr); }

    /* ── CARD ── */
    .card {
      border: 1px solid #e8e8e8;
      border-radius: 8px;
      padding: 18px 20px;
      background: #fff;
    }

    .card-label {
      font-size: 11px;
      font-weight: 500;
      color: #999;
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-bottom: 14px;
    }

    /* ── RESUME CARD ── */
    .resume-line {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      border-bottom: 1px solid #f0f0f0;
      font-size: 12px;
      color: #444;
    }

    .resume-line:last-child { border-bottom: none; }
    .resume-line strong { color: #111; font-weight: 500; }

    /* ── TABLE ── */
    table { width: 100%; border-collapse: collapse; }

    thead th {
      text-align: left;
      font-size: 11px;
      font-weight: 500;
      color: #999;
      padding-bottom: 10px;
      border-bottom: 1px solid #e8e8e8;
    }

    thead th:not(:first-child) { text-align: right; }

    tbody td {
      padding: 9px 0;
      border-bottom: 1px solid #f4f4f4;
      font-size: 12px;
      color: #333;
    }

    tbody tr:last-child td { border-bottom: none; }
    tbody td:not(:first-child) { text-align: right; }
    tbody tr:hover td { background: #fafafa; }

    /* ── CANVAS ── */
    canvas { display: block; width: 100% !important; }

    /* ── STAT MINI ── */
    .stat-mini { padding: 16px 18px; }
    .stat-mini .s-label { font-size: 11px; color: #999; margin-bottom: 6px; }
    .stat-mini .s-value { font-size: 22px; font-weight: 300; color: #111; letter-spacing: -.5px; }
    .stat-mini .s-sub   { font-size: 11px; color: #aaa; margin-top: 3px; }

    /* ── TOURS PAGE ── */
    .session-row {
      display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap;
    }

    .sess-btn {
      background: #fff;
      border: 1px solid #e8e8e8;
      border-radius: 6px;
      padding: 5px 14px;
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      color: #666;
      cursor: pointer;
      transition: all .15s;
    }

    .sess-btn.active, .sess-btn:hover {
      background: #111; color: #fff; border-color: #111;
    }

    .lap-header {
      display: grid;
      grid-template-columns: 36px 1fr 90px 80px 80px 80px;
      gap: 8px;
      font-size: 11px;
      font-weight: 500;
      color: #999;
      padding: 0 8px 8px;
      border-bottom: 1px solid #e8e8e8;
    }

    .lap-header span:not(:first-child) { text-align: right; }

    .lap-row {
      display: grid;
      grid-template-columns: 36px 1fr 90px 80px 80px 80px;
      gap: 8px;
      padding: 8px;
      font-size: 12px;
      color: #333;
      border-bottom: 1px solid #f4f4f4;
      transition: background .1s;
    }

    .lap-row:hover { background: #fafafa; }
    .lap-row span:not(:first-child) { text-align: right; }
    .lap-num { color: #bbb; font-size: 11px; }
    .lap-best-row { background: #fafafa; }
    .lap-best-row .lap-time { font-weight: 500; color: #111; }
    .sector-p { color: #7c3aed; }
    .sector-g { color: #059669; }
    .sector-y { color: #d97706; }

    /* ── CONDITIONS PAGE ── */
    .weather-big {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      margin-bottom: 20px;
    }

    .weather-big .temp {
      font-size: 56px;
      font-weight: 200;
      line-height: 1;
      letter-spacing: -2px;
      color: #111;
    }

    .weather-big .temp-unit { font-size: 20px; font-weight: 300; color: #888; margin-bottom: 8px; }
    .weather-desc { font-size: 13px; color: #666; margin-bottom: 4px; }
    .weather-loc  { font-size: 11px; color: #aaa; }

    .weather-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 16px;
    }

    .w-stat {
      border: 1px solid #e8e8e8;
      border-radius: 8px;
      padding: 14px 16px;
    }

    .w-stat .wl { font-size: 11px; color: #aaa; margin-bottom: 4px; }
    .w-stat .wv { font-size: 18px; font-weight: 300; color: #111; }

    .forecast-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
      border-bottom: 1px solid #f4f4f4;
      font-size: 12px;
      color: #444;
    }

    .forecast-row:last-child { border-bottom: none; }
    .forecast-day { width: 80px; color: #888; }
    .forecast-icon { width: 30px; text-align: center; }
    .forecast-temp { display: flex; gap: 8px; }
    .forecast-temp .hi { font-weight: 500; color: #111; }
    .forecast-temp .lo { color: #aaa; }
    .forecast-rain { font-size: 11px; color: #aaa; }

    .track-cond {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      border: 1px solid #e8e8e8;
      border-radius: 8px;
      margin-bottom: 10px;
    }

    .track-cond:last-child { margin-bottom: 0; }
    .track-cond .tc-icon { font-size: 20px; }
    .track-cond .tc-name { font-size: 13px; font-weight: 500; color: #111; }
    .track-cond .tc-desc { font-size: 11px; color: #aaa; margin-top: 2px; }
    .tc-active { border-color: #111; }
    .tc-inactive { opacity: .45; }

    .dot {
      width: 6px; height: 6px; border-radius: 50%;
      margin-left: auto; flex-shrink: 0;
    }

    .dot-black { background: #111; }
    .dot-gray  { background: #ccc; }

    /* ── PROFIL PAGE ── */
    .profile-top {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 20px;
      padding-bottom: 20px;
      border-bottom: 1px solid #e8e8e8;
    }

    .profile-av {
      width: 56px; height: 56px;
      border-radius: 50%;
      background: #111;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; font-weight: 300; color: #fff;
      flex-shrink: 0;
    }

    .profile-name { font-size: 20px; font-weight: 300; letter-spacing: -.5px; color: #111; }
    .profile-sub  { font-size: 12px; color: #aaa; margin-top: 3px; }
    .profile-record { margin-left: auto; text-align: right; }
    .profile-record .pr-val { font-size: 28px; font-weight: 200; letter-spacing: -1px; }
    .profile-record .pr-lbl { font-size: 11px; color: #aaa; margin-top: 2px; }

    .skill-wrap { margin-bottom: 12px; }
    .skill-top  { display: flex; justify-content: space-between; font-size: 12px; color: #666; margin-bottom: 5px; }
    .skill-top span:last-child { color: #111; font-weight: 500; }
    .skill-track { height: 3px; background: #f0f0f0; border-radius: 2px; }
    .skill-fill  { height: 100%; border-radius: 2px; background: #111; transition: width 1s ease; }

    .timeline { list-style: none; padding-left: 16px; border-left: 1px solid #e8e8e8; }

    .timeline li { padding: 0 0 18px 16px; position: relative; }
    .timeline li::before {
      content: '';
      position: absolute;
      left: -5px; top: 5px;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #fff;
      border: 1px solid #ccc;
    }

    .timeline li.tl-done::before { background: #111; border-color: #111; }
    .map-btn {
      background: #fff;
      border: 1px solid #e8e8e8;
      border-radius: 6px;
      padding: 4px 10px;
      font-family: 'Inter', sans-serif;
      font-size: 11px;
      color: #666;
      cursor: pointer;
      transition: all .15s;
    }
    .map-btn.active, .map-btn:hover { background: #111; color: #fff; border-color: #111; }

    .layer-item {
      display: flex; align-items: center; gap: 8px;
      padding: 7px 8px;
      border-radius: 7px;
      font-size: 12px; color: #444;
      cursor: pointer;
      transition: background .15s;
      margin-bottom: 2px;
    }
    .layer-item:hover  { background: #f4f4f4; }
    .layer-item.active { background: #111; color: #fff; }
    .layer-icon { font-size: 14px; width: 18px; text-align: center; }

    .wp-row {
      display: flex; justify-content: space-between;
      font-size: 12px; color: #555;
      padding: 4px 0;
      border-bottom: 1px solid #f4f4f4;
    }
    .wp-row:last-child { border-bottom: none; }
    .wp-row span:last-child { font-weight: 500; color: #111; }

    .legend-row {
      display: flex; align-items: center; gap: 8px;
      font-size: 11px; color: #555;
    }
    .legend-row div {
